# API Keys for LLM Providers
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Vector Store Configuration
WEAVIATE_URL=your_weaviate_instance_url
WEAVIATE_API_KEY=your_weaviate_api_key
VECTOR_STORE_TYPE=chroma  # Options: weaviate, chroma, faiss, pinecone
CHROMA_PERSIST_DIRECTORY=./vector_stores/chroma_db
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=your_index_name

# Database Configuration
DATABASE_URL=sqlite:///./models/resume_analyzer.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/resume_analyzer

# Application Settings
DEFAULT_LLM_PROVIDER=openai  # Options: openai, groq, google, anthropic
LLM_TEMPERATURE=0.1
MAX_TOKENS=2000
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Scoring Configuration
HARD_MATCH_WEIGHT=0.4
SEMANTIC_MATCH_WEIGHT=0.6
SIMILARITY_THRESHOLD=0.7

# File Upload Settings
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,docx,txt

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Web Application
HOST=0.0.0.0
PORT=8000
DEBUG=True
